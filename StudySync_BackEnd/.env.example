PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=studysync
DB_USER=postgres
DB_PASSWORD=your_password
DB_URI=postgresql://user:password@localhost:5432/studysync
DB_SSL=false

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Frontend (lien reset mot de passe)
FRONTEND_RESET_URL=http://localhost:8080

# Google OAuth (optionnel)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# SMTP (optionnel — mot de passe oublié)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="StudySync" <your_email@gmail.com>
